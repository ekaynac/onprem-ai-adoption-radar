__pycache__/
*.py[cod]
.pytest_cache/
.venv/
.venv-*/

# Brand kit (corporate identity originals, design files) is kept OUTSIDE this
# repo — never commit it here.
brand-kit/

# Local runtime data (generated by `radar init` / `radar scan`)
data/runs/
data/*.db
data/config.yaml
data/config.yaml.bak
# Durable history log: ignored by default so local/test timelines aren't
# committed. To version your history (recommended for self-hosting durability),
# `git add -f data/history.jsonl`. See docs/persistence.md.
data/history.jsonl
# Human decisions and discovery proposals (local runtime state).
data/overrides.yaml
data/proposed-seeds.yaml
data/proposed-model-seeds.yaml

# Coverage artifacts
.coverage
.coverage.*
htmlcov/

# macOS
.DS_Store

# Playwright MCP scratch artifacts
.playwright-mcp/
